# YouTube Data API v3（OAuth 2.0 クライアントシークレットのパス）
YOUTUBE_CLIENT_SECRET_PATH=./client_secret.json

# YouTube公開設定（public / unlisted / private）
YOUTUBE_PRIVACY=public

# チャンネルブランディング
CHANNEL_NAME=AIニュース1分解説
CHANNEL_HASHTAGS=#AIニュース #テックニュース #AI #海外テックニュース #ShortNews
CHANNEL_DESCRIPTION_FOOTER=海外の最新AI・テックニュースを毎日1分でお届けします。\nチャンネル登録で最新情報をいち早くチェック！

# 背景画像生成モデル（SD 1.5 互換の fine-tune モデルを指定可能）
# 例: Lykon/dreamshaper-8, SG161222/Realistic_Vision_V5.1_noVAE
SD_MODEL_ID=Lykon/dreamshaper-8

# VOICEVOX（ローカル起動時のURL）
VOICEVOX_URL=http://localhost:50021

# Context7 MCP（ドキュメント参照用）
CONTEXT7_API_KEY=...

